# ============================================================
# Vite & Gourmand — Backend env (exemple)
# ⚠️ Ne JAMAIS commit le .env réel — copier ce fichier en .env
# ============================================================

NODE_ENV=development
PORT=3001

# Frontend URL (CORS + reset password links)
APP_URL=http://localhost:5173

# JWT
JWT_SECRET=change-me-to-a-32-char-random-string-in-prod
JWT_EXPIRES_IN=7d

# Supabase PostgreSQL (BDD relationnelle)
SUPABASE_URL=https://uwzagqbyauuvivcvhxye.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# MongoDB (BDD NoSQL — dev: mongodb-memory-server / prod: Atlas)
# Laisser vide pour utiliser mongodb-memory-server en dev
MONGODB_URI=

# Resend (envoi mails)
RESEND_API_KEY=re_xxx
RESEND_FROM=onboarding@resend.dev

# Bcrypt
BCRYPT_ROUNDS=12
